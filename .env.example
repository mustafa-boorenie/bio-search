# Bio-Search Configuration
# Run /setup inside the TUI to configure interactively.

# Data storage directory (XPT files and DuckDB cache)
BIO_SEARCH_DATA_DIR=./data

# LLM provider: openai, anthropic, minimax, kimi, qwen, ollama
# Ollama runs locally and needs no API key.
BIO_SEARCH_LLM_PROVIDER=openai
BIO_SEARCH_LLM_API_KEY=sk-...

# Optional: override default model or endpoint
# BIO_SEARCH_LLM_MODEL=gpt-4o
# BIO_SEARCH_LLM_BASE_URL=https://...

# EWAS parameters
# BIO_SEARCH_EWAS_MIN_N=200
# BIO_SEARCH_FDR_ALPHA=0.05
